# Steam Web API
# Get yours free at: https://steamcommunity.com/dev/apikey
STEAM_API_KEY=your_steam_api_key_here

# Steam Profile IDs (64-bit Steam IDs)
# Find yours at: https://steamid.io
STEAM_ID_GRAHAM=76561198000000000
STEAM_ID_BROTHER=76561198000000001

# GitHub usernames (no key needed for public data, but token avoids rate limits)
NEXT_PUBLIC_GITHUB_USER_GRAHAM=your_github_username
NEXT_PUBLIC_GITHUB_USER_BROTHER=brothers_github_username
# Optional: https://github.com/settings/tokens (read:user, public_repo)
GITHUB_TOKEN=ghp_your_token_here

# Discord (optional — for pulling highlights from a channel)
# https://discord.com/developers/applications
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=
